# --- GMAIL / EMAIL ACCESS ---
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# --- SMS PARSING ---
# Place your SMS backup files (XML/JSON) in backend/data/sms/
SMS_BACKUP_DIR=./data/sms/

# --- WHATSAPP ---
# (Future use) Integration parameters
WHATSAPP_SESSION_ID=your-session-id

# --- SECURITY ---
# A custom passphrase to derive the encryption key (Optional)
# If left blank, a machine-specific key will be used.
MASTER_PASSPHRASE=
